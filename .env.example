# ===============================
# Concourse Event Watcher Config
# ===============================

# URL of the calendar page to monitor
CALENDAR_URL=https://concourseproject.com/calendar/

# Path inside container where state is stored
STATE_PATH=/app/data/seen_events.json

# Discord webhook URL
# Leave blank until configured
DISCORD_WEBHOOK_URL=

# Poll interval in seconds
POLL_SECONDS=120

# Prevent notifications on first run
FIRST_RUN_SILENT=true

# Optional jitter (helps avoid looking like a bot)
# Adds random seconds to each sleep cycle
JITTER_MIN_SECONDS=5
JITTER_MAX_SECONDS=20

# One-shot test mode
# When true, sends a single test notification and exits
TEST_MODE=false
