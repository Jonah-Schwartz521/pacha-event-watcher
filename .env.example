# ===============================
# Pacha NYC Event Watcher Config
# ===============================

# Discord webhook. Leave blank to run in dry-run mode (alerts logged, not sent).
DISCORD_WEBHOOK_URL=
ALERT_PREFIX=[Pacha]

# Poll interval. One HTTP request per cycle — the /events listing carries every
# event, tier, price and live stock count — so 300s is polite and plenty fast.
POLL_SECONDS=300
JITTER_MIN_SECONDS=0
JITTER_MAX_SECONDS=30

# CRITICAL fires when a tier has <= LOW_STOCK_ABS left, BUT capped at 35% of the
# tier's allocation (see diff.py) — so a 20-seat VIP tier that sold one ticket
# doesn't scream "almost gone" with 19 left. Both conditions must hold.
LOW_STOCK_ABS=20

# LOW fires at <= this fraction of allocation. Only reachable on larger tiers,
# which is the point: 10% of 20 seats is meaningless, 10% of 1000 is a warning.
LOW_STOCK_PCT=0.10

# Safety valve. If the site changes shape and the parser goes haywire, drop
# alerts rather than dump 200 messages. Priority-sorted, so urgent ones survive.
MAX_ALERTS_PER_CYCLE=15

# Named distinctly from the Concourse watcher's seen_events.json — the two run
# on the same VPS and must never collide.
STATE_PATH=/app/data/pacha_state.json

# Append-only stock log. Free (numbers are already in the response) and
# impossible to reconstruct later. Blank to disable.
HISTORY_PATH=/app/data/stock_history.jsonl

# First run records everything WITHOUT alerting, or it'd dump all 20 events.
FIRST_RUN_SILENT=true

# Container UID/GID. Leave unset on the VPS (runs as root, like Concourse).
# Set to 1000:1000 locally so data/ files aren't root-owned on your machine.
RUN_AS_UID=0
RUN_AS_GID=0

# ---- Testing ----
TEST_MODE=false
DRY_RUN=false